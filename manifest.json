{
  "manifest_version": 3,
  "name": "Overview Watch",
  "version": "0.1.0",
  "description": "Captures Google AI Overview and AI Mode compositions to a local audit log. Personal substrate-monitoring tool. Crimson Hexagonal Archive.",
  "author": "Lee Sharks",
  "homepage_url": "https://godkinggoogle.com/",

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://www.google.com/*",
    "https://google.com/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/search*",
        "https://google.com/search*"
      ],
      "js": [
        "lib/sam-v3.js",
        "lib/storage.js",
        "content/google.js"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Overview Watch — recent captures",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
